header.header
    nav.nav--tours
        a.nav__el(href='/') All tours

    .header__logo
        img(src='/img/logo-white.png' alt='Natours logo')

    nav.nav.nav--user
        if user
            a.nav__el.nav__el--logout Log out
            a.nav__el(href='/me')
                - var photoSrc = user.photo ? `/img/users/${user.photo}` : '/img/users/default.jpg'
                img.nav__user-img(src=photoSrc alt='Photo of #{user.name}')
                span= user.name.split(' ')[0]
        else
            a.nav__el(href='/login') Log in
            a.nav__el.nav__el--cta(href='#') Sign up
